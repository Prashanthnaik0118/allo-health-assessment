// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A product can have stock in multiple warehouses
  stockLevels  StockLevel[]
  reservations Reservation[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockLevels  StockLevel[]
  reservations Reservation[]
}

// Stock per product per warehouse
// KEY DESIGN: We track totalUnits and reservedUnits separately.
// availableUnits = totalUnits - reservedUnits
// This allows atomic reservation without race conditions.
model StockLevel {
  id            String    @id @default(cuid())
  productId     String
  warehouseId   String
  totalUnits    Int       @default(0)  // Physical stock in warehouse
  reservedUnits Int       @default(0)  // Units currently held by pending reservations

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])  // One stock entry per product per warehouse
}

// Reservation lifecycle:
// pending   → customer at checkout, units held for 10 minutes
// confirmed → payment succeeded, units permanently decremented
// released  → payment failed, timer expired, or user cancelled — units freed
model Reservation {
  id              String            @id @default(cuid())
  productId       String
  warehouseId     String
  quantity        Int
  status          ReservationStatus @default(pending)
  expiresAt       DateTime          // When this reservation auto-releases
  idempotencyKey  String?           @unique  // Bonus: prevent duplicate submissions
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

enum ReservationStatus {
  pending
  confirmed
  released
}
